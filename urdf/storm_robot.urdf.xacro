<?xml version="1.0"?>
<robot name="storm_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ===== Links ===== -->

  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.6 0.4 0.3"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.6 0.4 0.3"/></geometry>
    </collision>
    <inertial>
      <mass value="20.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.5" ixy="0" ixz="0" iyy="0.5" iyz="0" izz="0.5"/>
    </inertial>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>

  <!-- Left wheel -->
  <link name="wheel_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left_link"/>
    <origin xyz="0 0.2 -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Right wheel -->
  <link name="wheel_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right_link"/>
    <origin xyz="0 -0.2 -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Caster — fixed box instead of sphere to avoid DART physics assertion -->
  <link name="caster_link">
    <visual>
      <geometry><box size="0.1 0.1 0.1"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry><box size="0.1 0.1 0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_link"/>
    <origin xyz="0.25 0 -0.1" rpy="0 0 0"/>
  </joint>

  <!-- VLP-16: mounting plate -->
  <link name="velodyne_base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.0516" length="0.0717"/></geometry>
      <material name="dark_grey"><color rgba="0.2 0.2 0.2 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.0516" length="0.0717"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="velodyne_base_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="velodyne_base_link"/>
    <!-- 0.876m matches the real hardware offset used in master_launch.py -->
    <origin xyz="0 0 0.876" rpy="0 0 0"/>
  </joint>

  <!-- VLP-16: sensor frame (origin of published point cloud) -->
  <link name="velodyne">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.0516" length="0.0717"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <inertial>
      <mass value="0.83"/>
      <inertia ixx="0.000827" ixy="0" ixz="0" iyy="0.000827" iyz="0" izz="0.000827"/>
    </inertial>
  </link>

  <joint name="velodyne_base_scan_joint" type="fixed">
    <parent link="velodyne_base_link"/>
    <child link="velodyne"/>
    <origin xyz="0 0 0.03585" rpy="0 0 0"/>
  </joint>

  <!-- ===== Gazebo plugins (Ignition Fortress / ign-gazebo6 naming) ===== -->

  <!-- Differential drive: publishes /odom and odom->base_link TF -->
  <gazebo>
    <plugin filename="ignition-gazebo-diff-drive-system"
            name="ignition::gazebo::systems::DiffDrive">
      <left_joint>wheel_left_joint</left_joint>
      <right_joint>wheel_right_joint</right_joint>
      <wheel_separation>0.4</wheel_separation>
      <wheel_radius>0.1</wheel_radius>
      <odom_publish_frequency>20</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <min_velocity>-2</min_velocity>
      <max_velocity>2</max_velocity>
      <min_acceleration>-1</min_acceleration>
      <max_acceleration>1</max_acceleration>
    </plugin>
  </gazebo>

  <!-- Joint state publisher: feeds robot_state_publisher -->
  <gazebo>
    <plugin filename="ignition-gazebo-joint-state-publisher-system"
            name="ignition::gazebo::systems::JointStatePublisher">
      <topic>joint_states</topic>
    </plugin>
  </gazebo>

  <!-- Low friction on caster so it doesn't resist turning -->
  <gazebo reference="caster_link">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <!-- VLP16 GPU LiDAR sensor: 16-beam, ±15°, 0.3–25m, 10Hz -->
  <gazebo reference="velodyne">
    <sensor name="vlp16" type="gpu_lidar">
      <topic>/velodyne_points</topic>
      <update_rate>10</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>1800</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159265</min_angle>
            <max_angle>3.14159265</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <resolution>1</resolution>
            <min_angle>-0.26179939</min_angle>
            <max_angle>0.26179939</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.3</min>
          <max>25.0</max>
          <resolution>0.001</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
      <visualize>false</visualize>
      <always_on>true</always_on>
    </sensor>
  </gazebo>

</robot>
